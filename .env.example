# Telegram
BOT_TOKEN=123456:telegram-bot-token

# Provider: openai | anthropic
LLM_PROVIDER=openai

# OpenAI or OpenAI-compatible endpoint
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Claude native API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Agent
MAX_TOOL_ITERATIONS=6
MAX_RECENT_MESSAGES=12

# Storage
DATA_DIR=./data
DB_PATH=./data/agent.db
MCP_CONFIG_PATH=./mcp.servers.json

# TencentDB-Agent-Memory official release vendor/reference
TENCENT_MEMORY_VERSION=0.3.4
TENCENT_MEMORY_RELEASE_URL=https://github.com/Tencent/TencentDB-Agent-Memory/archive/refs/tags/v0.3.4.zip
TENCENT_MEMORY_VENDOR_DIR=./vendor/tencentdb-agent-memory/TencentDB-Agent-Memory-0.3.4
TENCENT_MEMORY_MODE=local

# TencentDB-Agent-Memory style local adapter
MEMORY_MAINTENANCE_CRON=*/10 * * * *
MEMORY_RECALL_STRATEGY=hybrid
MEMORY_RECALL_MAX_RESULTS=5
MEMORY_PIPELINE_EVERY_N_CONVERSATIONS=5
MEMORY_EXTRACTION_MAX_MEMORIES=20
MEMORY_PERSONA_TRIGGER_EVERY_N=50
MEMORY_L1_IDLE_TIMEOUT_SEC=600
MEMORY_L2_MIN_INTERVAL_SEC=900
MEMORY_ENABLE_DEDUP=true
MEMORY_OFFLOAD_ENABLED=true
MEMORY_OFFLOAD_MIN_CHARS=2500
MEMORY_OFFLOAD_SUMMARY_CHARS=900

# Autonomous agent loop: every 10 minutes by default
AUTONOMOUS_CRON=*/10 * * * *
AUTONOMOUS_MIN_INTERVAL_SEC=600
AUTONOMOUS_MAX_JOBS_PER_TICK=20
